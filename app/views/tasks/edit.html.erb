<div class="page-header">
  <h1 class="page-title">Edit Task</h1>
</div>

<div class="card">
  <%= form_with model: [@project, @task] do |form| %>
    <div class="form-group">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-input", placeholder: "Task name" %>
      <% if @task.errors[:name].any? %>
        <span style="color: var(--color-danger); font-size: 0.875rem;"><%= @task.errors[:name].first %></span>
      <% end %>
    </div>

    <div class="form-group">
      <%= form.label :description, class: "form-label" %>
      <%= form.text_area :description, class: "form-textarea", placeholder: "Task description (optional)" %>
    </div>

    <div class="form-group">
      <%= form.label :status, class: "form-label" %>
      <%= form.select :status, options_for_select([["To Do", "todo"], ["In Progress", "in_progress"], ["Done", "done"]], @task.status), {}, class: "form-select" %>
    </div>

    <div class="form-group">
      <%= form.label :due_date, class: "form-label" %>
      <%= form.date_field :due_date, class: "form-input" %>
    </div>

    <div style="display: flex; gap: 0.5rem;">
      <%= form.submit "Update Task", class: "btn btn-primary" %>
      <%= link_to "Cancel", @project, class: "btn btn-secondary" %>
    </div>
  <% end %>
</div>

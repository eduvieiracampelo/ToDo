<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-semibold dark:text-white"><%= t("projects.show") %>Teste</h1>
  <%= link_to t("projects.new_title"), new_project_path, class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium" %>
</div>

<div class="grid grid-cols-3 gap-4 mb-8">
  <div class="bg-white rounded-lg border border-gray-200 p-4 dark:bg-gray-800 dark:border-gray-700">
    <div class="text-3xl font-bold text-gray-900 dark:text-white"><%= @total_projects %></div>
    <div class="text-sm text-gray-500 dark:text-gray-400"><%= t("stats.total") %></div>
  </div>
  <div class="bg-white rounded-lg border border-gray-200 p-4 dark:bg-gray-800 dark:border-gray-700">
    <div class="text-3xl font-bold text-green-600 dark:text-green-400"><%= @completed_projects %></div>
    <div class="text-sm text-gray-500 dark:text-gray-400"><%= t("stats.completed") %></div>
  </div>
  <div class="bg-white rounded-lg border border-gray-200 p-4 dark:bg-gray-800 dark:border-gray-700">
    <div class="text-3xl font-bold text-amber-600 dark:text-amber-400"><%= @pending_projects %></div>
    <div class="text-sm text-gray-500 dark:text-gray-400"><%= t("stats.pending") %></div>
  </div>
</div>

<% if @projects.empty? %>
  <div class="bg-white rounded-lg border border-gray-200 p-12 text-center dark:bg-gray-800 dark:border-gray-700">
    <p class="text-gray-500 dark:text-gray-400 mb-4"><%= t("projects.no_projects") %></p>
    <%= link_to t("projects.create_link"), new_project_path, class: "px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors text-sm font-medium" %>
  </div>
<% else %>
  <% @projects.each do |project| %>
    <div class="bg-white rounded-lg border border-gray-200 p-6 mb-4 dark:bg-gray-800 dark:border-gray-700">
      <div class="flex justify-between items-start">
        <div>
          <%= link_to project.name, project, class: "text-lg font-semibold text-gray-900 hover:text-blue-600 transition-colors dark:text-white dark:hover:text-blue-400" %>
          <% if project.description.present? %>
            <p class="text-sm text-gray-500 mt-1 dark:text-gray-400"><%= project.description %></p>
          <% end %>
          <% if project.start_date.present? %>
            <p class="text-xs text-gray-400 mt-2 dark:text-gray-500">
              <% if project.end_date.present? %>
                <%= l(project.start_date, format: :short) %> - <%= l(project.end_date, format: :short) %>
              <% else %>
                <%= t("dates.started") %>: <%= l(project.start_date, format: :short) %>
              <% end %>
            </p>
          <% end %>
        </div>
        <div class="flex gap-2">
          <%= link_to t("projects.edit_link"), edit_project_path(project), class: "px-3 py-1.5 bg-gray-100 text-gray-700 rounded-md hover:bg-gray-200 transition-colors text-sm dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600" %>
          <%= button_to t("projects.delete"), project, method: :delete, class: "px-3 py-1.5 bg-red-600 text-white rounded-md hover:bg-red-700 transition-colors text-sm", form: { data: { turbo_confirm: "Are you sure?" } } %>
        </div>
      </div>
      <div class="flex gap-6 mt-4 text-sm text-gray-500 dark:text-gray-400">
        <span><strong class="text-gray-900 dark:text-white"><%= project.tasks.count %></strong> <%= t("projects.task_count") %></span>
        <span><strong class="text-gray-900 dark:text-white"><%= project.tasks.done.count %></strong> <%= t("projects.done_count") %></span>
        <span><strong class="text-gray-900 dark:text-white"><%= project.tasks.todo.count %></strong> <%= t("projects.todo_count") %></span>
        <span><strong class="text-gray-900 dark:text-white"><%= project.tasks.in_progress.count %></strong> <%= t("projects.in_progress_count") %></span>
      </div>
    </div>
  <% end %>
<% end %>

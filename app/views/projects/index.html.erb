<div class="page-header">
  <h1 class="page-title">Projects</h1>
  <%= link_to "New Project", new_project_path, class: "btn btn-primary" %>
</div>

<% if @projects.empty? %>
  <div class="card empty-state">
    <p>No projects yet. Create your first project to get started!</p>
    <%= link_to "Create Project", new_project_path, class: "btn btn-primary" %>
  </div>
<% else %>
  <% @projects.each do |project| %>
    <div class="card">
      <div class="card-header">
        <div>
          <%= link_to project.name, project, class: "card-title" %>
          <% if project.description.present? %>
            <p class="card-description"><%= project.description %></p>
          <% end %>
        </div>
        <div>
          <%= link_to "Edit", edit_project_path(project), class: "btn btn-secondary btn-sm" %>
          <%= button_to "Delete", project, method: :delete, class: "btn btn-danger btn-sm", form: { data: { turbo_confirm: "Are you sure?" } } %>
        </div>
      </div>
      <div class="project-stats">
        <span class="stat"><strong><%= project.tasks.count %></strong> tasks</span>
        <span class="stat"><strong><%= project.tasks.done.count %></strong> done</span>
        <span class="stat"><strong><%= project.tasks.todo.count %></strong> todo</span>
        <span class="stat"><strong><%= project.tasks.in_progress.count %></strong> in progress</span>
      </div>
    </div>
  <% end %>
<% end %>

<div class="flex justify-between items-start mb-6">
  <div>
    <h1 class="text-2xl font-semibold dark:text-white"><%= @project.name %></h1>
    <% if @project.description.present? %>
      <p class="text-sm text-gray-500 mt-1 dark:text-gray-400"><%= @project.description %></p>
    <% end %>
    <% if @project.start_date.present? %>
      <p class="text-sm text-gray-500 mt-2 dark:text-gray-400">
        <% if @project.end_date.present? %>
          <%= l(@project.start_date, format: :long) %> - <%= l(@project.end_date, format: :long) %>
        <% else %>
          <%= t("dates.started") %>: <%= l(@project.start_date, format: :long) %>
        <% end %>
      </p>
    <% end %>
  </div>
  <div class="flex gap-2">
    <%= link_to t("projects.edit_project"), edit_project_path(@project), class: "px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors text-sm font-medium dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600" %>
    <%= link_to t("projects.back"), projects_path, class: "px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors text-sm font-medium dark:bg-gray-700 dark:text-gray-200 dark:hover:bg-gray-600" %>
  </div>
</div>

<div class="bg-white rounded-lg border border-gray-200 p-6 dark:bg-gray-800 dark:border-gray-700">
  <div class="flex justify-between items-center mb-4">
    <h2 class="text-lg font-semibold dark:text-white"><%= t("projects.tasks_title") %></h2>
    <%= link_to t("tasks.add"), new_project_task_path(@project), class: "px-3 py-1.5 bg-blue-600 text-white rounded-md hover:bg-blue-700 transition-colors text-sm font-medium" %>
  </div>

  <% if @project.tasks.empty? %>
    <p class="text-gray-500 text-center py-8 dark:text-gray-400"><%= t("tasks.no_tasks") %></p>
  <% else %>
    <% if @project.tasks.in_progress.any? %>
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3 mt-4 dark:text-gray-400"><%= t("status.section_in_progress") %></h3>
      <div id="tasks_in_progress" class="space-y-2">
        <%= render partial: "tasks/task", collection: @project.tasks.in_progress, locals: { project: @project } %>
      </div>
    <% end %>

    <% if @project.tasks.todo.any? %>
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3 mt-4 dark:text-gray-400"><%= t("status.section_todo") %></h3>
      <div id="tasks_todo" class="space-y-2">
        <%= render partial: "tasks/task", collection: @project.tasks.todo, locals: { project: @project } %>
      </div>
    <% end %>

    <% if @project.tasks.done.any? %>
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3 mt-4 dark:text-gray-400"><%= t("status.section_done") %></h3>
      <div id="tasks_done" class="space-y-2">
        <%= render partial: "tasks/task", collection: @project.tasks.done, locals: { project: @project } %>
      </div>
    <% end %>
  <% end %>
</div>